# 璀璨星图 (迹向) 环境变量配置文件模板
# 请复制此文件并重命名为 .env，然后填入实际的值

# [JWT 认证]
# 用于签名 JWT Token，请使用随机强密码替换
SECRET_KEY=dev-secret-key-please-change

# [CORS 跨域配置]
# 允许前端访问后端 API 的来源域名，使用逗号分隔
# 生产环境请修改为实际前端地址，如：https://starmap.yourdomain.com
CORS_ORIGINS=*

# [SMTP 邮件发送配置]
# 用于发送验证码邮件
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_email_auth_code_here
