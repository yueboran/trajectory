# ==============================
# 构建与运行后端 Node.js API
# ==============================
FROM node:20-alpine

# 设置工作目录
WORKDIR /app

# 优先复制依赖文件并安装，利用 Docker 缓存加速构建
COPY package.json package-lock.json* ./
RUN npm install

# 复制源代码并执行构建
COPY . .
RUN npm run build

# 设置环境变量，指定生产模式和端口
ENV NODE_ENV=production
ENV PORT=8000

# 暴露后端端口
EXPOSE 8000

# 启动后端服务 (执行 server.cjs)
CMD ["npm", "start"]
